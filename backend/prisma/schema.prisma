generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  cashier
}

enum PaymentMethod {
  MPESA @map("M-Pesa")
  CASH  @map("Cash")
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  PAID
  FAILED
  CANCELLED
  PARTIAL_PAYMENT_FLAGGED
}

enum AuditStatus {
  SUCCESS
  FAILED
  WARNING
}

enum TableStatus {
  FREE
  OCCUPIED
  PENDING
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique @db.VarChar(40)
  pin       String
  role      UserRole @default(cashier)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bills     Bill[]
  auditLogs AuditLog[]

  @@index([role])
  @@map("users")
}

enum MenuCategory {
  MAINS           @map("Mains")
  SNACKS          @map("Snacks")
  HOT_BEVERAGES   @map("Hot Beverages")
  SIDES           @map("Sides")
  DRINKS          @map("Drinks")
  STAPLES         @map("Staples")
  VEGETABLES      @map("Vegetables")
}

model MenuItem {
  id        String       @id @default(uuid())
  name      String       @db.VarChar(120)
  price     Decimal      @db.Decimal(10, 2)
  category  MenuCategory @default(MAINS)
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  billItems BillItem[]

  @@index([isActive, category])
  @@map("menu_items")
}

model Bill {
  id                          String        @id @default(uuid())
  billNumber                  String        @unique @map("bill_number")
  total                       Decimal       @db.Decimal(12, 2)
  paymentMethod               PaymentMethod @map("payment_method")
  status                      PaymentStatus @default(PENDING)
  mpesaReceiptNumber          String?       @unique @map("mpesa_receipt_number") @db.VarChar(64)
  paymentPhone                String?       @map("payment_phone") @db.VarChar(20)
  failureReason               String?       @map("failure_reason")
  amountPaid                  Decimal?      @map("amount_paid") @db.Decimal(12, 2)
  amountDifference            Decimal       @default(0) @map("amount_difference") @db.Decimal(12, 2)
  mpesaTransactionDate        DateTime?     @map("mpesa_transaction_date")
  cashier                     String        @db.VarChar(40)
  cashierId                   String        @map("cashier_id")
  checkoutRequestId           String?       @unique @map("checkout_request_id") @db.VarChar(120)
  merchantRequestId           String?       @unique @map("merchant_request_id") @db.VarChar(120)
  callbackProcessedAt         DateTime?     @map("callback_processed_at")
  callbackProcessingStartedAt DateTime?     @map("callback_processing_started_at")
  lastCallbackReceivedAt      DateTime?     @map("last_callback_received_at")
  lastCallbackResultCode      Int?          @map("last_callback_result_code")
  lastPaymentAttemptAt        DateTime?     @map("last_payment_attempt_at")
  paymentLockExpiresAt        DateTime?     @map("payment_lock_expires_at")
  paymentAttempts             Int           @default(0) @map("payment_attempts")
  auditFlags                  String[]      @default([])
  createdAt                   DateTime      @default(now()) @map("created_at")
  updatedAt                   DateTime      @updatedAt @map("updated_at")

  cashierUser User     @relation(fields: [cashierId], references: [id], onDelete: Restrict)
  items       BillItem[]

  @@index([createdAt, cashierId])
  @@index([status, updatedAt])
  @@index([status, checkoutRequestId, updatedAt])
  @@index([paymentLockExpiresAt])
  @@index([callbackProcessingStartedAt])
  @@map("bills")
}

model BillItem {
  id         String   @id @default(uuid())
  billId     String   @map("bill_id")
  menuItemId String?  @map("menu_item_id")
  name       String   @db.VarChar(120)
  price      Decimal  @db.Decimal(10, 2)
  quantity   Int
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  bill     Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)
  menuItem MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([billId, sortOrder])
  @@map("bill_items")
}

model AuditLog {
  id            String      @id @default(cuid())
  actorId       String?     @map("actor_id")
  actorUsername String      @default("system") @map("actor_username")
  actorRole     String      @default("system") @map("actor_role")
  action        String
  entityType    String      @default("system") @map("entity_type")
  entityId      String?     @map("entity_id")
  status        AuditStatus @default(SUCCESS)
  ipAddress     String?     @map("ip_address")
  requestId     String?     @map("request_id")
  metadata      Json?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt, action])
  @@index([actorId])
  @@index([status])
  @@map("audit_logs")
}

model RestaurantProfile {
  id             String            @id @default(uuid())
  key            String            @unique @default("default")
  restaurantName String            @map("restaurant_name") @db.VarChar(120)
  currency       String            @default("KSH") @db.VarChar(10)
  timezone       String            @default("Africa/Nairobi") @db.VarChar(60)
  tables         RestaurantTable[]
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@map("restaurant_profiles")
}

model RestaurantTable {
  id        String           @id @default(uuid())
  profileId String           @map("profile_id")
  tableId   String           @map("table_id") @db.VarChar(80)
  name      String           @db.VarChar(80)
  status    TableStatus      @default(FREE)
  positionX Float            @default(0) @map("position_x")
  positionY Float            @default(0) @map("position_y")
  sortOrder Int              @default(0) @map("sort_order")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  profile RestaurantProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, tableId])
  @@index([profileId, sortOrder])
  @@map("restaurant_tables")
}
